# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/biovault

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# WebAuthn
WEBAUTHN_RP_NAME=BioVault
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:5173

# Blockchain (from contracts/deployments.json after running deploy)
FACTORY_ADDRESS=0x...
RECOVERY_MODULE_ADDRESS=0x...
ENTRY_POINT_ADDRESS=0x5FF137D4b0FDCD49DcA30c7CF57E578a026d2789
NETWORK_RPC_URL=http://localhost:8545
CHAIN_ID=31337

# Alchemy (for bundler in production)
ALCHEMY_API_KEY=your_alchemy_api_key
ALCHEMY_POLICY_ID=your_gas_manager_policy_id

# ZK Circuits paths
ZK_WASM_PATH=../circuits/build/biometric_commitment_js/biometric_commitment.wasm
ZK_ZKEY_PATH=../circuits/keys/proving_key.zkey
ZK_VERIFICATION_KEY_PATH=../circuits/keys/verification_key.json
